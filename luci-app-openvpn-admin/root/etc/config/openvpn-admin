
config settings 'global'
	option openvpn_instance 'myvpn'
	option openvpn_config_path '/etc/config/openvpn'
	option refresh_interval '2'
	option history_size '20'
	option blacklist_duration '600'
	option log_file '/tmp/openvpn.log'
	option history_file '/etc/openvpn/openvpn_connection_history.json'
	option blacklist_file '/etc/openvpn/blacklist.json'
	option easyrsa_dir '/etc/easy-rsa'
	option easyrsa_pki '/etc/easy-rsa/pki'
	option openvpn_pki '/etc/openvpn/pki'
	option logs_refresh_interval '10'
	option logs_display_lines '1000'
	option generate_client_script '/etc/openvpn/generate-client.sh'
	option renew_cert_script '/etc/openvpn/renewcert.sh'
	option blacklist_enabled '1'
	option logs_refresh_enabled '1'
	option refresh_enabled '1'
	option temp_dir '/tmp/openvpn-admin'
	option clean_garbage_enabled '0'
	option clean_garbage_time '4:50'
	option clean_garbage_script '/etc/openvpn/clean-garbage.sh'
	option server_template_path '/etc/openvpn/template/server.template'
	option ipv6_script_path '/etc/openvpn/openvpn_ipv6'
	option ipv6_script_interval '10'
	option ipv6_script_enabled '0'
	option hotplug_enabled '0'
	option hotplug_script_path '/etc/openvpn/openvpn_hotplug.sh'
	option hotplug_interface 'wan'
	option hotplug_ipv6_interface 'auto'
	option hotplug_ipv6_address '240e:3b0:1609:968d:252e:51fe:19a8:6514'
	option hotplug_firewall_enabled '1'
	option hotplug_firewall_name 'openvpn_ipv6'

